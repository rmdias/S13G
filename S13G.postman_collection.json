{
  "info": {
    "name": "S13G API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Upload Document",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Idempotency-Key",
            "value": "{{$guid}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "File",
              "type": "file",
              "src": "",
              "description": "Select an NFe/CTe/NFSe XML file"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/documents/upload",
          "host": ["{{baseUrl}}"],
          "path": ["documents", "upload"]
        },
        "description": "Upload and process a fiscal XML document (NFe, CTe or NFSe). Returns 201 with the new document id."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('documentId', json.id);",
              "    pm.test('Document created', () => pm.response.to.have.status(201));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "List Documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/documents?page=1&pageSize=20",
          "host": ["{{baseUrl}}"],
          "path": ["documents"],
          "query": [
            { "key": "page",      "value": "1" },
            { "key": "pageSize",  "value": "20" },
            { "key": "cnpj",      "value": "", "disabled": true },
            { "key": "uf",        "value": "", "disabled": true },
            { "key": "fromDate",  "value": "", "disabled": true, "description": "ISO 8601, e.g. 2025-01-01" },
            { "key": "toDate",    "value": "", "disabled": true, "description": "ISO 8601, e.g. 2025-12-31" }
          ]
        },
        "description": "Returns a paged list of documents. Enable optional query params to filter by CNPJ, state (UF), or date range."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has items array', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('items');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Document by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["documents", "{{documentId}}"]
        },
        "description": "Fetch a single document by its UUID. The documentId variable is auto-set after a successful Upload."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 404', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Document",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"state\": \"SP\",\n  \"status\": \"Processed\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["documents", "{{documentId}}"]
        },
        "description": "Update the state (UF) and status of a document. Does not modify the raw XML."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete Document",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["documents", "{{documentId}}"]
        },
        "description": "Permanently delete a document by its UUID."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
